# Copy this file to .env.local for private local testing.
# The real file is ignored by Git.
POKEBATTLE_ROM=/absolute/path/to/your/RunAndBun.gba
POKEBATTLE_STATE=/absolute/path/to/a/prebattle.ss0
POKEBATTLE_BATTLE_STATE=/absolute/path/to/a/prebattle.ss0
POKEBATTLE_PC_STATE=/absolute/path/to/a/route-start.ss0

# Optional vanilla Emerald profile. These stay local and are selected automatically
# whenever the app's Pokémon Emerald toggle is active.
POKEBATTLE_EMERALD_ROM=/absolute/path/to/PokemonEmerald.gba
POKEBATTLE_EMERALD_STATE=/absolute/path/to/an/early-game.ss1
POKEBATTLE_EMERALD_BATTLE_STATE=/absolute/path/to/a/prebattle.ss0
POKEBATTLE_EMERALD_PC_STATE=/absolute/path/to/a/pc-or-overworld.ss0
# MGBA_EXECUTABLE=/absolute/path/to/mGBA
