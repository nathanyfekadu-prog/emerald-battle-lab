# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# Local-only testing paths and executable overrides
.env
.env.*
!.env.example

# macOS and editor files
.DS_Store
.idea/
.vscode/

# Copyrighted game files and private player state
*.gba
*.gb
*.gbc
*.rom
*.sav
*.srm
*.ss[0-9]
